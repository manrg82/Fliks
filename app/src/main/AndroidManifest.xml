<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/logoapp"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/logoapp_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Fliks">
        <activity
            android:name=".view.BuscarActivity"
            android:exported="false"
            android:label="Buscar"
            android:theme="@style/Theme.Fliks" />
        <activity
            android:name=".data.DataStoreManager"
            android:exported="false"
            android:label="datastoremanager"
            android:theme="@style/Theme.Fliks" />
        <activity
            android:name=".viewmodel.MoviesViewModel"
            android:exported="false"
            android:label="moviesviewmodel"
            android:theme="@style/Theme.Fliks" />
        <activity
            android:name=".model.PeliculaTMDB"
            android:exported="false"
            android:label="@string/title_activity_pelicula_tmdb"
            android:theme="@style/Theme.Fliks" />
        <activity
            android:name=".view.PerfilActivity"
            android:exported="false"
            android:label="@string/title_activity_perfil"
            android:theme="@style/Theme.Fliks" />
        <activity
            android:name=".view.DetalleActivity"
            android:exported="false"
            android:label="@string/title_activity_detalle"
            android:theme="@style/Theme.Fliks" />
        <activity
            android:name=".model.Pelicula"
            android:exported="false"
            android:label="@string/title_activity_pelicula"
            android:theme="@style/Theme.Fliks" />
        <activity
            android:name=".view.LoginActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Fliks">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".view.RegistroActivity"
            android:exported="false"
            android:label="RegistroActivity"
            android:theme="@style/Theme.Fliks" />
        <activity
            android:name=".view.MainActivity"
            android:exported="false"
            android:label="Fliks"
            android:theme="@style/Theme.Fliks" />
        <service
            android:name=".service.MovieReminderService"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".service.MovieReminderReceiver"
            android:enabled="true"
            android:exported="false" />
    </application>

</manifest>